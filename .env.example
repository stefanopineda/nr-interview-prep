# Required: OpenAI API key used for Socratic evaluation (GPT-4o) and
# anchor-equation hints (Tier 3). Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Required only for /voice (voice-interviewer POC): xAI API key used for
# STT (/v1/stt), TTS (/v1/tts), and Grok-4 vision grading (/v1/chat/completions).
# Get one at https://console.x.ai
XAI_API_KEY=xai-...
